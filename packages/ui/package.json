{
  "name": "@aether/ui",
  "version": "0.0.1",
  "description": "shadcn-style UI components for Angular",
  "main": "dist/fesm2022/aether-ui.mjs",
  "module": "dist/fesm2022/aether-ui.mjs",
  "types": "dist/types/aether-ui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/aether-ui.d.ts",
      "import": "./dist/fesm2022/aether-ui.mjs",
      "require": "./dist/fesm2022/aether-ui.mjs",
      "default": "./dist/fesm2022/aether-ui.mjs"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "dist",
    "theme.css"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "test": "vitest"
  },
  "peerDependencies": {
    "@angular/common": ">=18.0.0 <22.0.0",
    "@angular/core": ">=18.0.0 <22.0.0",
    "@angular/forms": ">=18.0.0 <22.0.0"
  },
  "devDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "ng-packagr": "^21.2.2",
    "tsup": "^8.0.0",
    "typescript": "~5.9.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "angular",
    "ui",
    "components",
    "tailwind",
    "shadcn"
  ],
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^21.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-angular": "^1.0.0",
    "ngx-sonner": "^2.0.0",
    "tailwind-merge": "^3.4.0",
    "tslib": "^2.6.0"
  }
}
